{
  "name": "@pleaseai/spring",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Detect Spring versions from build files and install version-matched reference docs as Claude Code skills.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/pleaseai/spring-plugin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pleaseai/spring-plugin.git"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.13",
    "eslint": "10.2.1",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "typescript": "5.9.2",
    "typescript-eslint": "8.59.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --max-warnings 0 --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
